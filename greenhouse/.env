# ── Greenhouse CMS — Environment Variables ──────────────────────
# Copy this file to .env and fill in real values before starting.

# JSON Web Token secret for dashboard user sessions (min 32 chars)
JWT_SECRET="1234567ugfE#$%^&*IJHFDE%^&*(ijbvde456789ojbvdE$%^&^%$#@#$%^&*(IHVCXSW#$%^&*()))"

# API key the ESP32 sends in the X-Device-Key header
DEVICE_API_KEY="GH_VERSION_1"

# Server port
PORT=3000
